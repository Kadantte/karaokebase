Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,Muminki skradną serce Twe
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,bo są tak miłe, słodkie, że
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,zaciągną Cię w fantazji świat,
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,gdzie mnóstwo przygód czeka nas.
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,Bo to Muminki! Bo to Muminki!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,Daj mi dłoń i bądź jak chwat,
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,zabieram Cię w Muminków świat!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,Polećmy lotem ptaka, hen,
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,z nami do chmur, powitać dzień!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,Tam gdzie Muminki!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,Wasze Muminki! Nasze Muminki! Wasze Muminki!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,Nasze Muminki! Wasze Muminki! Nasze Muminki!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,pa, pa, pa, pa, pa, pa, pa, pa, pa, pa!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,ma, ma, ma, ma, ma, ma, ma, ma, ma, ma!
Comment: 0,0:00:00.00,0:00:00.00,Sample KM [Up] - ON,,0,0,0,,pa, pa, pa, pa, ma, ma, ma, ma, ma, pa!
